      "type": "integer",
      "nullable": true
    },
    "stat": {
      "$ref": "#/components/schemas/StatDefinition"
    },
    "value": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "nullable": true
    }
  }
}