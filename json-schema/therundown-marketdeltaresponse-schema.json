{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://therundown.io/schemas/MarketDeltaResponse",
  "title": "MarketDeltaResponse",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "delta_last_id": {
          "type": "string",
          "description": "Use this as `last_id` in the next request"
        },
        "count": {
          "type": "integer"
        },
        "has_more": {
          "type": "boolean",
          "description": "If true, there are more results \u2014 poll again immediately with the returned delta_last_id"
        }
      }
    },
    "deltas": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/MarketDeltaEntry"
      }
    }
  }
}