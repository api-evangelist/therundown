{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://therundown.io/schemas/ChartSeries",
  "title": "ChartSeries",
  "type": "object",
  "properties": {
    "affiliate_name": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "t": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp"
          },
          "p": {
            "type": "string",
            "description": "Price"
          },
          "c": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Closed at timestamp"
          }
        }
      }
    }
  }
}