{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://therundown.io/schemas/MarketParticipant",
  "title": "MarketParticipant",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "market_event_id": {
      "type": "integer",
      "format": "int64"
    },
    "participant_id": {
      "type": "integer"
    },
    "participant_type": {
      "type": "string",
      "enum": [
        "TYPE_TEAM",
        "TYPE_PLAYER",
        "TYPE_RESULT"
      ]
    },
    "participant_name": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}