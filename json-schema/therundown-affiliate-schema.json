{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://therundown.io/schemas/Affiliate",
  "title": "Affiliate",
  "type": "object",
  "properties": {
    "affiliate_id": {
      "type": "integer",
      "example": 19
    },
    "affiliate_name": {
      "type": "string",
      "example": "Draftkings"
    },
    "affiliate_url": {
      "type": "string",
      "example": "https://draftkings.com"
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Region"
      }
    }
  }
}